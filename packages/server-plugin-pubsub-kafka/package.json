  "main": "./dist/index.js", "module": "./dist/index.js", "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist"], "sideEffects": false,
  "scripts": { "build": "tsc -p tsconfig.build.json", "test": "tsx tests/kafka.test.ts" },
  "dependencies": { "@youneed/server-plugin-pubsub": "workspace:*" },
  "peerDependencies": { "kafkajs": ">=2" },
  "peerDependenciesMeta": { "kafkajs": { "optional": true } },
  "devDependencies": { "@youneed/test": "workspace:*", "@youneed/test-reporter-console": "workspace:*" }
}
