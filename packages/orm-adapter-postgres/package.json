  "description": "PostgreSQL adapter for @youneed/orm-sql (node-postgres/`pg`-backed).",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
