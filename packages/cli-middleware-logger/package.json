{
  "name": "@youneed/cli-middleware-logger",
  "version": "0.1.0",
  "description": "Logger middleware for @youneed/cli: adds this.logger (a @youneed/logger instance) with level wired from --verbose/--quiet flags.",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx tests/logger.test.ts"
  },
  "peerDependencies": {
    "@youneed/cli": "workspace:*",
    "@youneed/logger": "workspace:*"
  },
  "devDependencies": {
    "@youneed/cli": "workspace:*",
    "@youneed/logger": "workspace:*",
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*"
  }
}
