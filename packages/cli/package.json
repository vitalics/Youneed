{
  "name": "@youneed/cli",
  "version": "0.1.0",
  "description": "Type-safe, Commander-style CLI framework on the @youneed factory-class pattern.",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx tests/cli.test.ts && tsx tests/render.test.ts"
  },
  "dependencies": {
    "@youneed/schema": "workspace:*"
  },
  "devDependencies": {
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*"
  }
}
