    "test": "tsx tests/completion.test.ts"
  },
  "peerDependencies": { "@youneed/cli": "workspace:*" },
  "devDependencies": {
    "@youneed/cli": "workspace:*",
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*"
  }
}
