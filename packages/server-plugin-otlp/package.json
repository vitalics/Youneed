{
  "name": "@youneed/server-plugin-otlp",
  "version": "0.1.0",
  "description": "@youneed/server plugin: export per-request traces over OTLP/HTTP (JSON) to an OpenTelemetry collector / Jaeger / Tempo — no OTel SDK — with a devtools tab.",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./devtools": { "types": "./dist/devtools.d.ts", "default": "./dist/devtools.js" }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/devtools.js",
    "./src/devtools.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx tests/otlp.test.ts"
  },
  "dependencies": {
    "@youneed/server": "workspace:*",
    "@youneed/server-middleware-trace": "workspace:*"
  },
  "devDependencies": {
    "@youneed/dom": "workspace:*",
    "@youneed/dom-ui-shad": "workspace:*",
    "@youneed/server-plugin-devtools": "workspace:*",
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*"
  }
}
