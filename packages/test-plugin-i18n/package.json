{
  "name": "@youneed/test-plugin-i18n",
  "version": "0.1.0",
  "description": "Translation parity checks for @youneed/test: assert no missing/extra keys or drifted placeholders across locales.",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx tests/parity.test.ts"
  },
  "dependencies": {
    "@youneed/i18n": "workspace:*"
  },
  "peerDependencies": {
    "@youneed/test": "workspace:*"
  },
  "devDependencies": {
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*"
  }
}
