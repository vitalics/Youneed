{
  "name": "@youneed/server-plugin-rbac",
  "version": "0.1.0",
  "description": "@youneed/server plugin + controller provider + guard for @youneed/rbac: request-scoped `this.can`, an `authorize(action, resource)` guard, a roles/check introspection API, and a devtools RBAC tab.",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./devtools": { "types": "./dist/devtools.d.ts", "default": "./dist/devtools.js" }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/devtools.js",
    "./src/devtools.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx tests/rbac.test.ts"
  },
  "dependencies": {
    "@youneed/server": "workspace:*",
    "@youneed/rbac": "workspace:*"
  },
  "devDependencies": {
    "@youneed/dom": "workspace:*",
    "@youneed/dom-ui-shad": "workspace:*",
    "@youneed/server-plugin-devtools": "workspace:*",
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*"
  }
}
