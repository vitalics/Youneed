{
  "name": "@youneed/ssr-plugin-speculation",
  "version": "0.1.0",
  "description": "SSR page middleware for @youneed/ssr: inject the Speculation Rules API <script> (prefetch/prerender) from a page's declared rules.",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx tests/speculation.test.ts"
  },
  "dependencies": {
    "@youneed/ssr": "workspace:*",
    "@youneed/server-plugin-ssr": "workspace:*"
  },
  "devDependencies": {
    "@youneed/server": "workspace:*",
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*"
  }
}
