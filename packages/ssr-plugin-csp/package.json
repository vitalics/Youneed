{
  "name": "@youneed/ssr-plugin-csp",
  "version": "0.1.0",
  "description": "SSR Content-Security-Policy for @youneed: per-request nonce, header builder, and inline-script nonce injection for document responses.",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx tests/csp.test.ts"
  },
  "dependencies": {
    "@youneed/server": "workspace:*",
    "@youneed/server-plugin-ssr": "workspace:*"
  },
  "devDependencies": {
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*"
  }
}
