  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist"], "sideEffects": false,
  "scripts": { "build": "tsc -p tsconfig.build.json", "test": "tsx tests/rabbitmq.test.ts" },
  "dependencies": { "@youneed/server-plugin-pubsub": "workspace:*" },
  "peerDependencies": { "amqplib": ">=0.10" },
  "peerDependenciesMeta": { "amqplib": { "optional": true } },
  "devDependencies": { "@youneed/test": "workspace:*", "@youneed/test-reporter-console": "workspace:*", "amqplib": "^0.10.4", "@types/amqplib": "^0.10.5" }
