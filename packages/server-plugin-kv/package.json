{
  "name": "@youneed/server-plugin-kv",
  "version": "0.1.0",
  "description": "Mount a KV store (from @youneed/server-plugin-store) as a ServerPlugin for @youneed/server: tracks reads/writes/hit-rate + surfaces a live key browser in @youneed/server-plugin-devtools (Infra card, header tab, flow node). Re-exports the KV contract.",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "default": "./dist/devtools.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/devtools.js",
    "./src/devtools.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx tests/kv.test.ts"
  },
  "dependencies": {
    "@youneed/server": "workspace:*",
    "@youneed/server-plugin-store": "workspace:*"
  },
  "devDependencies": {
    "@youneed/test": "workspace:*",
    "@youneed/test-reporter-console": "workspace:*",
    "@youneed/dom": "workspace:*",
    "@youneed/dom-ui-shad": "workspace:*",
    "@youneed/server-plugin-devtools": "workspace:*"
  }
}
