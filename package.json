{
  "name": "@youneed/monorepo",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm --filter-prod \"@youneed/server-plugin-devtools...\" --filter-prod \"@youneed/server...\" --filter-prod \"@youneed/dom-ui-shad...\" run build && pnpm --filter \"./packages/*\" --filter \"!@youneed/server-plugin-devtools\" run build && pnpm --filter \"@youneed/server-plugin-devtools\" --filter \"@youneed/cli-plugin-devtools\" run build:web",
    "typecheck": "tsc -p tsconfig.json",
    "test": "pnpm -r run test && pnpm examples:test:dom",
    "bench": "pnpm -r --workspace-concurrency=1 run bench",
    "ci:release": "changeset",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:publish": "pnpm build && changeset publish",
    "site:gen": "node site/scripts/gen-packages.mjs",
    "site:dev": "pnpm site:gen && node site/scripts/build-client.mjs && tsx site/src/index.ts",
    "site:build": "pnpm site:gen && node site/scripts/build-client.mjs && tsx site/scripts/generate.mjs",
    "site:serve": "node scripts/serve-site.mjs",
    "site:open": "OPEN=/ node scripts/serve-site.mjs",
    "site:variants": "OPEN=/,/index-brutalist.html,/index-atmospheric.html node scripts/serve-site.mjs",
    "package:create": "create-youneedpackage",
    "examples:build": "pnpm build && pnpm examples:build:dom && pnpm examples:build:raf && pnpm examples:build:priority && pnpm examples:build:styles && pnpm examples:build:portal && pnpm examples:build:tailwind && pnpm examples:build:styles-merge && pnpm examples:build:scheduler-react && pnpm examples:build:dom-vs-react && pnpm examples:build:cascade && pnpm examples:build:router-hash && pnpm examples:build:router-query && pnpm examples:build:router-slash && pnpm examples:build:compose && pnpm examples:build:providers && node examples/ssg/build.mjs && node examples/pages/build.mjs && node examples/crud/build.mjs && node examples/video/build.mjs",
    "examples:build:dom": "node examples/dom/build.mjs",
    "examples:serve:dom": "pnpm examples:build:dom && node packages/server/src/serve.mjs examples/dom",
    "examples:build:raf": "node examples/raf/build.mjs",
    "examples:serve:raf": "pnpm examples:build:raf && node packages/server/src/serve.mjs examples/raf",
    "examples:build:priority": "node examples/priority/build.mjs",
    "examples:serve:priority": "pnpm examples:build:priority && node packages/server/src/serve.mjs examples/priority",
    "examples:build:styles": "node examples/styles/build.mjs",
    "examples:serve:styles": "pnpm examples:build:styles && node packages/server/src/serve.mjs examples/styles",
    "examples:build:portal": "node examples/portal/build.mjs",
    "examples:serve:portal": "pnpm examples:build:portal && node packages/server/src/serve.mjs examples/portal",
    "examples:build:tailwind": "node examples/tailwind/build.mjs",
    "examples:serve:tailwind": "pnpm examples:build:tailwind && node packages/server/src/serve.mjs examples/tailwind",
    "examples:build:styles-merge": "node examples/styles-merge/build.mjs",
    "examples:serve:styles-merge": "pnpm examples:build:styles-merge && node packages/server/src/serve.mjs examples/styles-merge",
    "examples:build:scheduler-react": "node examples/scheduler-react/build.mjs",
    "examples:serve:scheduler-react": "pnpm examples:build:scheduler-react && node packages/server/src/serve.mjs examples/scheduler-react",
    "examples:build:cascade": "node examples/cascade/build.mjs",
    "examples:serve:cascade": "pnpm examples:build:cascade && node packages/server/src/serve.mjs examples/cascade",
    "examples:build:task-restart": "node examples/task-restart/build.mjs",
    "examples:serve:task-restart": "pnpm examples:build:task-restart && node packages/server/src/serve.mjs examples/task-restart",
    "examples:build:router-hash": "node examples/router-hash/build.mjs",
    "examples:serve:router-hash": "pnpm examples:build:router-hash && node packages/server/src/serve.mjs examples/router-hash",
    "examples:build:compose": "node examples/compose/build.mjs",
    "examples:serve:compose": "pnpm examples:build:compose && node packages/server/src/serve.mjs examples/compose",
    "examples:build:providers": "node examples/providers/build.mjs",
    "examples:serve:providers": "pnpm examples:build:providers && node packages/server/src/serve.mjs examples/providers",
    "examples:ssg": "node examples/ssg/build.mjs && tsx examples/ssg/generate.ts",
    "examples:ssg:serve": "pnpm examples:ssg && node packages/server/src/serve.mjs examples/ssg",
    "examples:ssr": "tsx examples/ssr/bin-ssr.ts",
    "examples:server": "tsx examples/http/bin-server.ts",
    "examples:serve:server": "tsx examples/server/server.ts",
    "examples:serve:server-devtools": "pnpm --filter @youneed/server-plugin-devtools build:web && tsx examples/server-devtools/server.ts",
    "examples:cli:devtools": "pnpm --filter @youneed/cli-plugin-devtools build:web && tsx examples/cli/bin.ts devtools",
    "examples:cache": "tsx examples/cache/bin-cache.ts",
    "examples:upload": "tsx examples/upload/bin-upload.ts",
    "examples:orm:mysql": "tsx examples/orm-mysql/bin.ts",
    "examples:orm:mongo": "tsx examples/orm-mongo/bin.ts",
    "examples:test:dom": "tsx examples/dom/bin-dom.test.ts",
    "examples:pages": "node examples/pages/build.mjs && tsx examples/pages/bin-pages.ts",
    "examples:crud": "node examples/crud/build.mjs && tsx examples/crud/bin.ts",
    "examples:video": "node examples/video/build.mjs && tsx examples/video/bin-video.ts",
    "examples:vite:dev": "vite -c examples/vite/vite.config.ts",
    "examples:vite:build": "vite build -c examples/vite/vite.config.ts",
    "examples:vite:ssg": "node --import tsx examples/vite/prerender.mjs",
    "examples:vite:serve": "pnpm examples:vite:ssg && node packages/server/src/serve.mjs examples/vite/dist-ssg",
    "examples:build:router-query": "node examples/router-query/build.mjs",
    "examples:serve:router-query": "pnpm examples:build:router-query && node packages/server/src/serve.mjs examples/router-query",
    "examples:build:router-slash": "node examples/router-slash/build.mjs",
    "examples:serve:router-slash": "pnpm examples:build:router-slash && node packages/server/src/serve.mjs examples/router-slash --spa",
    "examples:build:shad": "node examples/shad/build.mjs",
    "examples:serve:shad": "pnpm examples:build:shad && tsx examples/shad/bin-shad.ts",
    "examples:build:dom-vs-react": "node examples/dom-vs-react/build.mjs",
    "examples:serve:dom-vs-react": "pnpm examples:build:dom-vs-react && node packages/server/src/serve.mjs examples/dom-vs-react"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@happy-dom/global-registrator": "^20.10.5",
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@youneed/ts-plugin": "workspace:*",
    "create-youneedpackage": "workspace:*",
    "esbuild": "^0.28.1",
    "githops": "^0.5.3",
    "happy-dom": "^20.10.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "vue": "^3.5.38"
  },
  "dependencies": {
    "@youneed/cli": "workspace:*",
    "@youneed/cli-middleware-color": "workspace:*",
    "@youneed/cli-middleware-logger": "workspace:*",
    "@youneed/cli-middleware-music": "workspace:*",
    "@youneed/cli-middleware-oscillator": "workspace:*",
    "@youneed/cli-middleware-prompt": "workspace:*",
    "@youneed/cli-plugin-devtools": "workspace:*",
    "@youneed/devtools": "workspace:*",
    "@youneed/dom": "workspace:*",
    "@youneed/dom-adapter-react": "workspace:*",
    "@youneed/dom-provider-a11y": "workspace:*",
    "@youneed/dom-provider-timers": "workspace:*",
    "@youneed/dom-provider-virtual": "workspace:*",
    "@youneed/dom-router": "workspace:*",
    "@youneed/server": "workspace:*",
    "@youneed/server-middleware-static": "workspace:*",
    "@youneed/ssr": "workspace:*",
    "@youneed/ssr-plugin-speculation": "workspace:*",
    "@youneed/vite-plugin": "workspace:*"
  }
}
